---
import { getCollection } from 'astro:content';
import siteData from '../content/site/general.json';

const studios = (await getCollection('studios')).sort((a, b) => a.data.order - b.data.order);
const { cafe } = siteData;
---

<section class="studios bg-beige" id="studios">
    <div class="container">
        <h2 class="section-title text-raisin">Studios</h2>

        {studios.map((studio, index) => {
            const d = studio.data;
            const isFirst = index === 0;
            return (
                <div class="category-accordion">
                    <button
                        class="category-banner"
                        aria-expanded={isFirst ? 'true' : 'false'}
                        data-studio={studio.id}
                    >
                        <img
                            src={d.image}
                            alt={d.name}
                            class="category-banner-img category-banner-img--blurred"
                            loading="lazy"
                        />
                        <div class="category-banner-overlay">
                            <i class="fas fa-door-open"></i>
                            <span class="category-banner-label">{d.name}</span>
                            <i class="fas fa-chevron-down category-chevron"></i>
                        </div>
                    </button>

                    <div class="category-panel" style={isFirst ? '' : 'max-height: 0;'}>
                        <div class="course-single-card">
                            <div class="studio-image-wrapper">
                                <img src={d.image} alt={d.name} class="studio-image" loading="lazy" data-studio-name={d.name} />
                            </div>
                            <div class="studio-content">
                                <h3 class="studio-name">{d.name}</h3>
                                <p class="studio-description">{d.description}</p>
                            </div>
                        </div>
                    </div>
                </div>
            );
        })}

        <div class="category-accordion">
            <button class="category-banner" aria-expanded="false" data-studio="empfangsbereich">
                <img
                    src={cafe.images[0]}
                    alt="Empfangsbereich"
                    class="category-banner-img category-banner-img--blurred"
                    loading="lazy"
                />
                <div class="category-banner-overlay">
                    <i class="fas fa-mug-hot"></i>
                    <span class="category-banner-label">{cafe.subtitle}</span>
                    <i class="fas fa-chevron-down category-chevron"></i>
                </div>
            </button>
            <div class="category-panel" style="max-height: 0;">
                <div class="course-single-card">
                    <div class="studio-image-wrapper">
                        <img src={cafe.images[0]} alt="Empfangsbereich" class="studio-image" loading="lazy" data-studio-name="Empfangsbereich" />
                    </div>
                    <div class="studio-content">
                        <h3 class="studio-name">{cafe.subtitle}</h3>
                        <p class="studio-description">{cafe.description}</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div id="studio-lightbox" class="studio-lightbox">
    <button class="studio-lightbox-close" aria-label="Schließen">&times;</button>
    <img class="studio-lightbox-img" src="" alt="">
    <div class="studio-lightbox-caption"></div>
</div>
